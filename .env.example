# Dozzle-Enhanced AI Log Analysis Agent — Environment Configuration

# ── LLM API Keys (Required for AI features) ────────────────────────────────

# Claude API (primary LLM provider)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API (fallback provider)
OPENAI_API_KEY=sk-...

# Ollama (local/offline mode, no key needed)
OLLAMA_BASE_URL=http://localhost:11434

# ── Dozzle / Docker Configuration ────────────────────────────────────────────

# Dozzle HTTP API URL
DOZZLE_BASE_URL=http://localhost:8080

# Docker socket path (for direct Docker SDK access)
# DOCKER_SOCKET=/var/run/docker.sock

# Mock mode for testing (generates synthetic logs)
DOZZLE_MOCK=false

# ── Agent Configuration ────────────────────────────────────────────────────

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# API server host and port
API_HOST=0.0.0.0
API_PORT=8766

# ── Model Cache ─────────────────────────────────────────────────────────────

# HuggingFace model cache directory
HF_CACHE_DIR=./models

# Model idle unload time in seconds (600 = 10 minutes)
# HF_IDLE_UNLOAD_SECONDS=600

# Device preference: auto, cpu, cuda
HF_DEVICE=auto

# ── Memory / Storage ───────────────────────────────────────────────────────

# SQLite database path
DB_PATH=data/dozzle_agent.db

# Data directory
DATA_DIR=/app/data

# Log retention in days
RETENTION_DAYS=7

# Max log rows in SQLite
MAX_LOG_ROWS=10000000

# ── Anomaly Detection ─────────────────────────────────────────────────────

# Expected fraction of anomalous logs (0.01 - 0.10)
ANOMALY_CONTAMINATION=0.05

# Lines needed to train Isolation Forest
ANOMALY_BOOTSTRAP_SIZE=500

# Lines between model retrains
ANOMALY_RETRAIN_INTERVAL=10000

# Isolation Forest score cutoff
ANOMALY_IF_THRESHOLD=-0.3

# ── LLM Configuration ───────────────────────────────────────────────────────

# Provider priority: claude, openai, ollama
LLM_PROVIDER_PRIORITY=claude,openai,ollama

# Claude model
LLM_CLAUDE_MODEL=claude-opus-4-8

# OpenAI model
LLM_OPENAI_MODEL=gpt-4o

# Ollama model
LLM_OLLAMA_MODEL=llama3

# Maximum retries for LLM calls
LLM_MAX_RETRIES=3

# ── Alerting ─────────────────────────────────────────────────────────────────

# Webhook URL for anomaly notifications
# ALERT_WEBHOOK_URL=https://your-webhook.com/anomalies

# Webhook bearer token
# ALERT_WEBHOOK_TOKEN=your-secret-token

# Minimum alert severity: LOW, MEDIUM, HIGH, CRITICAL
ALERT_MIN_SEVERITY=HIGH

# Alert deduplication window in seconds
ALERT_DEDUP_SECONDS=300

# ── Security ────────────────────────────────────────────────────────────────

# Require user consent for LLM processing
SECURITY_LLM_CONSENT_REQUIRED=true

# Redact sensitive data from logs
SECURITY_REDACT_SENSITIVE=true

# Enable offline mode (Ollama only, no external API calls)
SECURITY_OFFLINE_MODE=false

# ── Knowledge Updater ───────────────────────────────────────────────────────

# Enable automated knowledge base updates
KNOWLEDGE_UPDATER_ENABLED=true

# Update schedule (cron format)
KNOWLEDGE_SCHEDULE="0 2 * * 0"

# GitHub token for release API (optional)
# GITHUB_TOKEN=ghp_...

# ── Performance ────────────────────────────────────────────────────────────

# Batch size for log processing
INGESTION_BATCH_SIZE=50

# Batch timeout in milliseconds
INGESTION_BATCH_TIMEOUT_MS=100

# Max queue size for backpressure
INGESTION_MAX_QUEUE_SIZE=50000

# ── Development ────────────────────────────────────────────────────────────

# Enable debug mode
DEBUG=false

# Enable profiling
PROFILING_ENABLED=false

# Test mode (skips some ML operations)
TEST_MODE=false
