# Dozzle-Enhanced AI Log Analysis Agent — Environment Variables
# Copy to .env and fill in your values

# ── LLM API Keys (at least one required) ────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
OLLAMA_BASE_URL=http://localhost:11434   # For local Ollama (no API key needed)

# ── Dozzle / Docker connection ────────────────────────────────────────────
DOZZLE_BASE_URL=http://localhost:8080   # Dozzle HTTP API base URL
DOZZLE_MOCK=false                       # Set to 'true' for testing without Docker

# ── HuggingFace ──────────────────────────────────────────────────────────
HF_CACHE_DIR=./models                   # Local cache directory for HF models
# HF_TOKEN=your_hf_token               # Only needed for gated models

# ── GitHub (optional — increases GitHub API rate limits) ─────────────────
# GITHUB_TOKEN=your_github_pat

# ── Alerting (optional) ──────────────────────────────────────────────────
# WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# ── Agent settings ───────────────────────────────────────────────────────
LOG_LEVEL=INFO
DATA_DIR=./data                         # SQLite database storage

# ── GPU (optional) ───────────────────────────────────────────────────────
# CUDA_VISIBLE_DEVICES=0                # Set to GPU index, or empty to force CPU
